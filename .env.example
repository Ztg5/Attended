# Neon pooled connection string (used by Prisma Client at runtime)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Optional: direct (non-pooled) connection for migrations. If unset, Prisma uses DATABASE_URL.
# DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# --- Auth (Auth.js / NextAuth) ---
# Secret used to sign session JWTs. Generate one with:  npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="change-me"
# Google OAuth client (create at https://console.cloud.google.com → Credentials → OAuth client ID,
# type "Web application"). Authorized redirect URI: https://YOUR_DOMAIN/api/auth/callback/google
# and http://localhost:3000/api/auth/callback/google for local dev.
AUTH_GOOGLE_ID="xxxx.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="xxxx"
# (Invite code removed — sign-up is open to any Google account.)

# Only for the one-time migration / CSV import: the owner's Google sign-in email.
# OWNER_EMAIL="you@gmail.com"
