# Neon pooled connection string (used by Prisma Client at runtime)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Optional: direct (non-pooled) connection for migrations. If unset, Prisma uses DATABASE_URL.
# DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Optional shared secret to protect write routes (Phase 2 middleware). Not required for Phase 1.
# WRITE_SECRET="change-me"
