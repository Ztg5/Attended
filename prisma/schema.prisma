// Attended — multi-user schema
// Games are GLOBAL (one row per real-world game, shared by everyone). Each user's
// personal attendance + private notes live in Attendance. Auth via Auth.js (Google).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- Auth (Auth.js / NextAuth standard Prisma schema) -----------------------
// User is our own record keyed to the Google identity via Account.providerAccountId.

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique // handle for social features; chosen on first sign-in
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  // Unguessable public-share token. Null = profile is private (the default).
  // Set by "share my profile", cleared by revoking. Anyone holding the token can
  // read this user's dashboard highlights at /s/<token> — never their notes.
  shareToken String? @unique

  accounts    Account[]
  sessions    Session[]
  attendances Attendance[]

  requestsSent     Friendship[] @relation("RequestsSent")
  requestsReceived Friendship[] @relation("RequestsReceived")

  // The user's own favorite teams — records/streaks are computed for these (per-user).
  favoriteTeams Team[] @relation("UserFavoriteTeams")
}

// Friend graph with request/approve. A single row per pair (either direction); friends
// once status = "accepted". `@@unique([requesterId, addresseeId])` plus an app-level
// check for the reverse pair prevents duplicate requests.
model Friendship {
  id          String    @id @default(cuid())
  requester   User      @relation("RequestsSent", fields: [requesterId], references: [id], onDelete: Cascade)
  requesterId String
  addressee   User      @relation("RequestsReceived", fields: [addresseeId], references: [id], onDelete: Cascade)
  addresseeId String
  status      String    @default("pending") // pending | accepted
  createdAt   DateTime  @default(now())
  respondedAt DateTime?

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@index([requesterId, status])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// One user's attendance of one (global) game. Personal notes live here — never on
// Game — and are private to the user. Unique on (userId, gameId): you attend a game once.
model Attendance {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameId    Int
  notes     String? // personal memories — private to this user
  favoritedAt DateTime? // non-null = one of the user's favorite games (capped at 4 in app)
  createdAt DateTime @default(now())

  @@unique([userId, gameId])
  @@index([userId])
  @@index([gameId])
}

model League {
  id    Int    @id @default(autoincrement())
  code  String @unique // NFL / MLB / NBA / NHL
  name  String
  teams Team[]
  games Game[]
}

model Team {
  id           Int     @id @default(autoincrement())
  league       League  @relation(fields: [leagueId], references: [id])
  leagueId     Int
  espnTeamId   String // ESPN's team id — the anchor for exact game matching
  name         String // "Buffalo Bills"
  nickname     String // "Bills"
  location     String? // "Buffalo"
  abbreviation String // "BUF"
  logoUrl      String?
  primaryColor String? // hex, no leading '#'
  // ESPN's alternateColor. Pairs with primaryColor for the Zubaz profile banner —
  // the pair is what makes teams distinguishable (primaries cluster in navy/black).
  secondaryColor String? // hex, no leading '#'
  active       Boolean @default(true)

  homeGames   Game[]       @relation("HomeTeam")
  awayGames   Game[]       @relation("AwayTeam")
  gamePlayers GamePlayer[]
  favoritedBy User[]       @relation("UserFavoriteTeams")

  @@unique([leagueId, espnTeamId])
  @@index([leagueId])
}

model Venue {
  id          Int     @id @default(autoincrement())
  espnVenueId String  @unique // one venue = one ESPN id, regardless of name changes
  name        String // current name
  city        String?
  state       String?
  latitude    Float?
  longitude   Float?
  nameHistory Json? // optional: names ESPN has used over time
  games       Game[]
}

model Game {
  id         Int      @id @default(autoincrement())
  league     League   @relation(fields: [leagueId], references: [id])
  leagueId   Int
  date       DateTime
  seasonYear Int

  homeTeam   Team? @relation("HomeTeam", fields: [homeTeamId], references: [id])
  homeTeamId Int?
  awayTeam   Team? @relation("AwayTeam", fields: [awayTeamId], references: [id])
  awayTeamId Int?

  venue   Venue? @relation(fields: [venueId], references: [id])
  venueId Int?

  homeScore Int?
  awayScore Int?

  status          String // final / pending / needs_review
  espnEventId     String? @unique
  isPostseason    Boolean @default(false)
  postseasonRound String?
  wentToOvertime  Boolean @default(false)
  attendance      Int?
  detailsJson     Json? // raw-ish ESPN blob: line scores, broadcast, weather, notes

  // Provenance / review bookkeeping
  claimedResult String? // the CSV's claimed_result, kept for auditing
  matchNote     String? // why it needs review, or what was corrected during import

  createdAt DateTime @default(now())

  gamePlayers GamePlayer[]
  attendances Attendance[]

  @@index([leagueId])
  @@index([date])
  @@index([status])
}

// A person. Deduped on ESPN player id (never on name) so a traded player stays
// one record across teams.
model Player {
  id           Int          @id @default(autoincrement())
  espnPlayerId String       @unique
  name         String
  position     String?
  headshotUrl  String?
  isMvp        Boolean      @default(false) // won a league MVP (backfilled from ESPN awards)
  gamePlayers  GamePlayer[]
}

// One player's appearance in one attended game. `stats` is a free-form JSON map of
// ESPN box-score stat key -> numeric value (categories stored as-is; no fixed schema).
model GamePlayer {
  id       Int    @id @default(autoincrement())
  game     Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameId   Int
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  playerId Int
  team     Team?  @relation(fields: [teamId], references: [id])
  teamId   Int?
  stats    Json // { "passingYards": 287, "passingTouchdowns": 3 }

  @@unique([gameId, playerId])
  @@index([playerId])
  @@index([gameId])
}
